  <project name="meta-imx" remote="imx" path="sources/meta-imx" revision="[whinlatter-commit]" upstream="whinlatter">
     <linkfile src="tools/imx-setup-release.sh" dest="imx-setup-release.sh"/>
     <linkfile src="README" dest="README-IMXBSP"/>
  </project>
  <project name="meta-nxp-connectivity" remote="imx" path="sources/meta-nxp-connectivity" revision="[whinlatter-commit]" upstream="whinlatter"/>
  <project name="meta-nxp-demo-experience" remote="imx-support" path="sources/meta-nxp-demo-experience" revision="[whinlatter-commit]" upstream="whinlatter"/>

